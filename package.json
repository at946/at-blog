{
	"name": "at-blog",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.7.0",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"check:astro": "astro check",
		"check:type": "tsc --project tsconfig.json --pretty --noEmit",
		"biome:check": "biome check src",
		"biome:write": "biome check --write src",
		"lint:markdown": "markdownlint-cli2 {*,.*}/**/*.{md,mdx,mdoc}",
		"lint:markdown:fix": "markdownlint-cli2 --fix {*,.*}/**/*.{md,mdx,mdoc}",
		"create:article": "bash utils/commands/create-article.sh",
		"lefthook": "lefthook run pre-commit",
		"add:amazonLink": "python3 utils/python/addAmazonItem.py",
		"reinstall": "pnpm clean --lockfile && pnpm i"
	},
