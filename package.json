		"@astrojs/svelte": "^8.1.2",
		"@biomejs/biome": "2.5.0",
		"@tailwindcss/aspect-ratio": "^0.4.2",
		"@tailwindcss/typography": "^0.5.19",
		"@types/gtag.js": "^0.0.20",
		"@types/katex": "^0.16.8",
		"@types/node": "^25.9.1",
		"astro": "^6.4.7",
		"astro-icon": "^1.1.5",
